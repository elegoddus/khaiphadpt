{
  "manifest_version": 3,
  "name": "CS Suggestion Assistant (Sidebar)",
  "version": "2.0",
  "description": "Hệ thống gợi ý câu trả lời DVKH thông minh. Tương thích mọi nền tảng chat.",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Bật/Tắt CS Assistant Sidebar"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}
